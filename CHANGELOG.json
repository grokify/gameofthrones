      "highlights": [
        { "description": "Unified Cobra CLI (`got`) replacing 5 separate command binaries" },
        { "description": "Comprehensive unit tests for characters, organizations, and demo data generation" }
      ],
      "breaking": [
        { "description": "CLI commands moved from separate binaries to unified `got` command. Install with: `go install github.com/grokify/gameofthrones/cmd/got@latest`", "commit": "527d82e" }
      ],
      "added": [
        { "description": "`got` CLI with Cobra for unified command interface", "commit": "527d82e" },
        { "description": "`got show characters` command with `--query` and `--format` flags", "commit": "527d82e" },
        { "description": "`got show organizations` command with `--query` and `--format` flags", "commit": "527d82e" },
        { "description": "`got salesforce` subcommands: create-accounts, create-contacts, create-cases, delete-accounts, delete-contacts", "commit": "527d82e" },
        { "description": "`got pipedrive` subcommands: create-orgs, create-people, get-persons, get-org-fields", "commit": "527d82e" },
        { "description": "`got ringcentral build` command with `--output`, `--pretty`, and `--from-file` flags", "commit": "527d82e" },
        { "description": "GoDoc comments for all exported types and functions", "commit": "22bb9b7" },
        { "description": "Named constants: `csvColumnCount`, `areaCodeStride`, `phoneNumberStart`, `defaultFallbackDomain`", "commit": "22bb9b7" }
      ],
      "changed": [
        { "description": "Improved panic messages with descriptive context", "commit": "22bb9b7" },
        { "description": "Use empty struct for set membership in `acsOrgs` map (zero memory)", "commit": "22bb9b7" },
        { "description": "Salesforce screenshots moved to `docs/images/salesforce/`", "commit": "432522d" }
      ],
      "removed": [
        { "description": "`cmd/build_data/` directory (replaced by `got ringcentral build`)", "commit": "527d82e" },
        { "description": "`cmd/pipedrive/` directory (replaced by `got pipedrive`)", "commit": "527d82e" },
        { "description": "`cmd/salesforce/` directory (replaced by `got salesforce`)", "commit": "527d82e" },
        { "description": "`cmd/read_simple/` directory (replaced by `got show characters`)", "commit": "527d82e" },
        { "description": "`cmd/test_numbers/` directory (converted to unit tests)", "commit": "527d82e" },
        { "description": "~60 lines of commented-out dead code in `characters.go`", "commit": "22bb9b7" }
      ],
      "tests": [
        { "description": "`TestCharacters`: verify embedded CSV loads correctly", "commit": "3182643" },
