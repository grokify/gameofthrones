        { "description": "`TestOrganizations`: verify organization list is populated", "commit": "3182643" },
        { "description": "`TestGetDemoOrganizations`: verify area codes and phone generation", "commit": "3182643" },
        { "description": "`TestGetDemoCharacters`: verify unique phone numbers and emails", "commit": "3182643" },
        { "description": "`TestDemoCharactersNamesSorted`: verify alphabetical sorting", "commit": "3182643" }
      ],
